---
import Section from "@/components/Section.astro";

import { basics } from "@cv";
const { summary } = basics;
---

<Section title="Sobre mi">
  <p>
    {summary}
  </p>
</Section>

<style>
  p {
    /* Esto hace que los saltos de línea en el texto se vean en la web */
    white-space: pre-line; 
    line-height: 1.6;
    text-wrap: pretty;
    color: #444;
  }
</style>